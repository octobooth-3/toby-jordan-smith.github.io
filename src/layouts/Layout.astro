---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = "Tailspin Toys", description = "Find your next game!" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <main class="container">
      <slot />
    </main>
  </body>
</html>

